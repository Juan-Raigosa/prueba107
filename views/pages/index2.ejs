<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
</head>
<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <table class="table">
            <thead>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Precio</th>
                <th>Imagen</th>
            <tbody>
                <% productos.forEach(function(producto){ %>
                <tr>
                    <td><%= producto.title %></td>
                    <td><%= producto.description %></td>
                    <td><%= producto.price %></td>
                    <td> <img src="<%= producto.image %>" width="100px"></td>
                </tr>
                <%})%>
            </tbody>
            </table>
        </div>
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>
</html>
